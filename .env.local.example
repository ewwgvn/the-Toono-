# ── Supabase (기존) ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# 서비스 롤 키 — checkout API에서 auth.users 이메일 조회에 필요
# Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── App URL ─────────────────────────────────────────────────────
# QPay 콜백 URL 구성에 사용 (트레일링 슬래시 없이)
NEXT_PUBLIC_APP_URL=https://the-toono.vercel.app

# ── Prisma / Database ────────────────────────────────────────────
# Supabase PostgreSQL — Transaction pooler (port 6543)
DATABASE_URL=postgresql://postgres.xxxx:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Supabase PostgreSQL — Direct connection (port 5432, Prisma migrate용)
DIRECT_URL=postgresql://postgres.xxxx:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres

# ── QPay ────────────────────────────────────────────────────────
# QPay 계정 정보 (https://merchant.qpay.mn 에서 확인)
QPAY_ENV=production           # development | production
QPAY_USERNAME=ULIGER_WORLD
QPAY_PASSWORD=your_qpay_password
QPAY_INVOICE_CODE=ULIGER_WORLD_INVOICE

# 웹훅 콜백 검증 토큰 (임의 랜덤 문자열 32자 이상)
QPAY_CALLBACK_SECRET=change_me_to_random_secret_32chars

# ── Payout (정산 지급) ────────────────────────────────────────────
# MANUAL: 관리자가 수동으로 지급 (기본값, Khan Bank API 불필요)
# KHAN_API: 자동 Khan Bank 이체
PAYOUT_MODE=MANUAL

# ── Cron 인증 ─────────────────────────────────────────────────────
# /api/cron/payouts 엔드포인트 인증 토큰
CRON_SECRET=change_me_to_random_cron_secret

# ── Khan Bank (PAYOUT_MODE=KHAN_API 일 때만 필요) ─────────────────
# KHAN_BANK_BASE_URL=https://api.khanbank.com
# KHAN_BANK_CLIENT_ID=your_client_id
# KHAN_BANK_CLIENT_SECRET=your_client_secret
# KHAN_BANK_ACCOUNT_NO=your_sender_account_number
